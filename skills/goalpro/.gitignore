# GoalPro 提交 Skill 源文件，不提交本机运行状态。

# Graphify 生成产物
graphify-out/

# Meta_Kim 本地运行状态和缓存
.meta-kim/

# Codex 本机配置、hook、排障脚本通常含绝对路径，不提交
.codex/

# Claude Code 本机配置和项目级 hooks 不随 Skill 发布
.claude/settings.json
.claude/settings.local.json
.claude/project-task-state.json

